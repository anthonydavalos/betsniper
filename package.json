{
  "name": "betsniper-v3",
  "version": "1.0.0",
  "description": "Sistema de Arbitraje y Live Trading Deportivo (Altenar/Pinnacle)",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "spy:altenar": "node scripts/spy-altenar-profile.js",
    "spy:acity:deep": "node scripts/spy-acity-live-socket-deep.js --require-profile=acity --headed --capture-ms=1200000 --login-wait-ms=240000 --max-frames=60000 --max-widget-bodies=5000",
    "spy:booky:history": "node scripts/spy-booky-history.js --headed --wait-close",
    "spy:booky:history:headless": "node scripts/spy-booky-history.js --capture-ms=120000",
    "spy:booky:cashflow": "node scripts/spy-booky-cashflow.js --headed --wait-close",
    "spy:booky:cashflow:headless": "node scripts/spy-booky-cashflow.js --capture-ms=120000",
    "analyze:acity:live": "node scripts/analyze-acity-live-socket.js --headed --wait-close --require-profile=acity --all-headers",
    "analyze:acity:live:headless": "node scripts/analyze-acity-live-socket.js --require-profile=acity --capture-ms=120000 --all-headers",
    "sync:booky:pnl-base": "node scripts/sync-booky-pnl-base-from-spy.js",
    "sync:booky:pnl-base:acity": "node scripts/sync-booky-pnl-base-from-spy.js --profile=acity",
    "capture:booky": "node scripts/capture-altenar-betslip.js --headed",
    "capture:booky:headless": "node scripts/capture-altenar-betslip.js",
    "capture:booky:acity": "node scripts/capture-altenar-betslip.js --headed --require-profile=acity",
    "capture:booky:acity:headless": "node scripts/capture-altenar-betslip.js --require-profile=acity",
    "capture:booky:dorado": "node scripts/capture-altenar-betslip.js --headed --require-profile=doradobet",
    "capture:booky:dorado:headless": "node scripts/capture-altenar-betslip.js --require-profile=doradobet",
    "capture:pinnacle:placement": "node scripts/capture-pinnacle-placement.js --headed --wait-close",
    "capture:pinnacle:placement:headless": "node scripts/capture-pinnacle-placement.js --capture-ms=180000",
    "capture:pinnacle:account": "node scripts/capture-pinnacle-account.js --headed --wait-close --all-arcadia --all-xhr",
    "capture:pinnacle:account:headless": "node scripts/capture-pinnacle-account.js --capture-ms=180000 --all-arcadia --all-xhr",
    "token:booky": "node scripts/extract-booky-auth-token.js --headed",
    "token:booky:wait-close": "node scripts/extract-booky-auth-token.js --headed --wait-close",
    "token:booky:acity": "node scripts/extract-booky-auth-token.js --headed --require-profile=acity",
    "token:booky:acity:wait-close": "node scripts/extract-booky-auth-token.js --headed --wait-close --require-profile=acity",
    "token:booky:dorado": "node scripts/extract-booky-auth-token.js --headed --require-profile=doradobet",
    "token:booky:dorado:wait-close": "node scripts/extract-booky-auth-token.js --headed --wait-close --require-profile=doradobet",
    "health:latency": "node scripts/health-latency.js",
    "ingest:pinnacle:force": "node scripts/ingest-pinnacle.js --force",
    "ingest:pinnacle:safe": "node scripts/ingest-pinnacle.js --force --no-incremental-flush",
    "cleanup:booky:orphans": "node scripts/cleanup-booky-orphans.js",
    "migrate:booky:legacy-integration": "node scripts/migrate-booky-legacy-integration.mjs --apply",
    "migrate:booky:legacy-integration:aggressive": "node scripts/migrate-booky-legacy-integration.mjs --aggressive --apply",
    "smoke:booky": "node scripts/smoke-booky.js",
    "smoke:booky:live": "node scripts/smoke-booky.js --live",
    "book:dorado": "node scripts/set-book-profile.js dorado",
    "book:acity": "node scripts/set-book-profile.js acity",
    "pinnacle:gateway": "node services/pinnacleGateway.js"
  },
  "keywords": [
    "trading",
    "betting",
    "arbitrage",
    "value-betting"
  ],
  "author": "BetSniper Architect",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.7.9",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "decimal.js": "^10.4.3",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "lowdb": "^7.0.1",
    "mqtt": "^5.15.1",
    "puppeteer": "^24.37.2",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
