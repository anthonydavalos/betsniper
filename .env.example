# Environment
NODE_ENV=development
PORT=3000

# Altenar Profile (autogenerado por set-book-profile.js)
# Flujo recomendado:
#   npm run book:dorado
#   npm run book:acity
# Este archivo es plantilla; el .env real lo actualiza el script.
BOOK_PROFILE=acity
ALTENAR_INTEGRATION=acity
ALTENAR_ORIGIN=https://www.casinoatlanticcity.com
ALTENAR_REFERER=https://www.casinoatlanticcity.com/apuestas-deportivas
ALTENAR_COUNTRY_CODE=PE
ALTENAR_CULTURE=es-ES
ALTENAR_TIMEZONE_OFFSET=300
ALTENAR_NUM_FORMAT=en-GB
ALTENAR_DEVICE_TYPE=1
ALTENAR_SPORT_ID=0

# Perfil PUBLICO para scanners (OBLIGATORIO)
# Debe coincidir con BOOK_PROFILE/ALTENAR_INTEGRATION para evitar cruces de feed.
# Si BOOK_PROFILE=acity => usar dominio acity. Si BOOK_PROFILE=doradobet => usar doradobet.
ALTENAR_PUBLIC_INTEGRATION=acity
ALTENAR_PUBLIC_ORIGIN=https://www.casinoatlanticcity.com
ALTENAR_PUBLIC_REFERER=https://www.casinoatlanticcity.com/apuestas-deportivas
ALTENAR_PUBLIC_COUNTRY_CODE=PE
ALTENAR_PUBLIC_CULTURE=es-ES
ALTENAR_PUBLIC_TIMEZONE_OFFSET=300
ALTENAR_PUBLIC_NUM_FORMAT=en-GB
ALTENAR_PUBLIC_DEVICE_TYPE=1
ALTENAR_PUBLIC_SPORT_ID=0
ALTENAR_PUBLIC_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/143.0.0.0 Safari/537.36

# Overrides avanzados (opcionales)
# ALTENAR_WIDGET_BASE_URL=https://sb2frontend-altenar2.biahosted.com/api/widget
# ALTENAR_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/143.0.0.0 Safari/537.36
# ALTENAR_ACCEPT_LANGUAGE=es-ES,es;q=0.9,en;q=0.8

# Fase 1.1 - Captura controlada de login/betslip (Puppeteer)
# Recomendado para ACity:
ALTENAR_BOOKY_URL=https://www.casinoatlanticcity.com/apuestas-deportivas#/overview
ALTENAR_LOGIN_USERNAME=
ALTENAR_LOGIN_PASSWORD=
BOOKY_CAPTURE_MS=120000

# Fase 1.2 - Token real placeWidget
ALTENAR_BOOKY_AUTH_TOKEN=
# Token de widget (scanner/live/prematch): mantener formato crudo, sin forzar Bearer
ALTENAR_WIDGET_AUTH_TOKEN=
# Webhook Google Apps Script para sincronizar token en hoja TOKEN!A1
GSHEETS_TOKEN_WEBHOOK_URL=
BOOKY_REAL_PLACEMENT_ENABLED=true
BOOKY_KEEP_REAL_PLACEMENT_ON_TOKEN_REFRESH=false
# Checklist rapido (operacion real segura):
# 1) Validar token: GET /api/booky/token-health
# 2) Validar captura: GET /api/booky/capture/latest (found=true)
# 3) Ejecutar dry-run: POST /api/booky/real/dryrun/:id
# 4) Recien ahi pasar BOOKY_REAL_PLACEMENT_ENABLED=true
# 5) Al terminar sesion, volver a false

# Auto-renovación asistida (abre Chrome si token está vencido o por vencer)
BOOKY_AUTO_TOKEN_REFRESH_ENABLED=true
BOOKY_TOKEN_MIN_REMAINING_MINUTES=2
# Auto-renovación para sync de balance/historial (Booky account snapshot)
BOOKY_AUTO_TOKEN_REFRESH_SYNC_ENABLED=false
BOOKY_SYNC_TOKEN_MIN_REMAINING_MINUTES=2
# Cooldown anti-bucle para autorenovación del token widget ante 401/403 (ms)
ALTENAR_WIDGET_TOKEN_RENEW_COOLDOWN_MS=120000
# Timeout de captura del script de renovación automática del token widget (ms)
ALTENAR_WIDGET_TOKEN_RENEW_TIMEOUT_MS=90000

# Guardas de valor al ejecutar apuesta real (evitar entradas sin edge)
BOOKY_MIN_EV_PERCENT=2
BOOKY_MAX_ODD_DROP=0.20
# Drift maximo permitido entre prepare/confirm (semi-auto / auto-snipe)
# Sube BOOKY_LIVE_MAX_ODD_DRIFT en mercados muy volatiles para reducir REQUOTE_REQUIRED.
BOOKY_LIVE_MAX_ODD_DRIFT=0.08
BOOKY_PREMATCH_MAX_ODD_DRIFT=0.20

# Saneo de apuestas activas huérfanas (si no existen en Open Bets remoto)
BOOKY_ORPHAN_ACTIVE_GRACE_MS=120000
BOOKY_ORPHAN_ACTIVE_HARD_MAX_MS=1200000
# Filtro opcional para cashflow de depósitos/retiros (formato YYYY-MM-DD)
BOOKY_CASHFLOW_FROM_DATE=

# Diagnóstico y umbrales del matcher (Pinnacle ↔ Altenar)
MATCH_DIAGNOSTIC_LOG=1
# Valores válidos para MATCH_DIAGNOSTIC_LOG: 1/0, true/false, yes/no, on/off
MATCH_FUZZY_THRESHOLD=0.77
MATCH_MIN_ACCEPT_SCORE=0.60
# Rangos válidos de umbral: 0.00 a 1.00
MATCH_TIME_TOLERANCE_MINUTES=5
MATCH_TIME_EXTENDED_TOLERANCE_MINUTES=30
# Rango recomendado de minutos: 1 a 30 (acepta hasta 180)

# Pinnacle Gateway - estabilidad de login manual
# URL/ventana de captura para fase 1 (placement contract discovery)
PINNACLE_CAPTURE_URL=https://www.pinnacle.com/es/soccer/matchups/live/
PINNACLE_CAPTURE_MS=180000
PINNACLE_CAPTURE_MAX_BODY_CHARS=24000
PINNACLE_REAL_PLACEMENT_ENABLED=false
PINNACLE_AUTO_CLOSE_ON_VALID_SOCKET=true
PINNACLE_AUTO_CLOSE_MIN_READY_MS=0
PINNACLE_AUTO_CLOSE_DELAY_MS=1800
PINNACLE_ARCADIA_MIN_SOCKETS=1
PINNACLE_STALE_RELOAD_GRACE_MS=600000
PINNACLE_STALE_RELOAD_ALLOW_DURING_GRACE=true
PINNACLE_STALE_CHECK_INTERVAL_MS=1000
PINNACLE_STALE_TRIGGER_MIN_INTERVAL_MS=3600000
PINNACLE_STALE_TIME_DIFF_MINUTES=6
PINNACLE_GATEWAY_AUTOSTART=true
PINNACLE_GATEWAY_AUTOSTART_MIN_INTERVAL_MS=3600000
PINNACLE_GATEWAY_TRIGGER_CHECK_INTERVAL_MS=5000
# Perfil dedicado para Arcadia/Pinnacle (separado de Booky/Altenar)
PINNACLE_CHROME_PROFILE_DIR=data/pinnacle/chrome-profile
PINNACLE_AUTO_LOGIN_ENABLED=false
PINNACLE_LOGIN_USERNAME=
PINNACLE_LOGIN_PASSWORD=
# En Windows/OneDrive suele ser mas estable en false para evitar colisiones de escritura.
PINNACLE_INGEST_INCREMENTAL_FLUSH_ENABLED=false
PINNACLE_INGEST_INCREMENTAL_FLUSH_EVERY_LEAGUES=8
# Intervalo del cron de ingesta Pinnacle (ms). Default 2h; para 1h usar 3600000.
PINNACLE_INGEST_CRON_INTERVAL_MS=7200000
# Throttling opcional del polling Live HTTP cuando WS Arcadia está sano
# (reduce carga sin perder snapshot periódico de consistencia)
PINNACLE_LIVE_HTTP_MAX_STALE_MS=20000
PINNACLE_LIVE_WS_FRESH_WINDOW_MS=8000

# Prematch WS Arcadia (MQTT) + fallback polling
DISABLE_PINNACLE_PREMATCH_WS=false
PINNACLE_PREMATCH_WS_DISCOVERY_INTERVAL_MS=600000
PINNACLE_PREMATCH_WS_SAVE_INTERVAL_MS=15000
PINNACLE_PREMATCH_WS_HEALTH_CHECK_INTERVAL_MS=12000
PINNACLE_PREMATCH_WS_STALE_MS=70000
PINNACLE_PREMATCH_WS_FALLBACK_POLL_INTERVAL_MS=45000
PINNACLE_PREMATCH_WS_SAFETY_POLL_INTERVAL_MS=360000
PINNACLE_PREMATCH_WS_LEAGUE_LIMIT=120
PINNACLE_PREMATCH_WS_INCLUDE_REG_TOPICS=true
PINNACLE_PREMATCH_WS_INCLUDE_SPC_TOPICS=true

# Altenar Prematch Scheduler (capacidad adaptativa)
# Base: capacidad normal por tick
ALTENAR_PREMATCH_SCHEDULER_LOOP_TICK_MS=20000
ALTENAR_PREMATCH_SCHEDULER_MAX_CONCURRENCY=3
ALTENAR_PREMATCH_SCHEDULER_MAX_EVENTS_PER_TICK=6
# Burst: se activa cuando hay backlog stale en eventos vinculados cercanos
ALTENAR_PREMATCH_SCHEDULER_BURST_ENABLED=true
ALTENAR_PREMATCH_SCHEDULER_BURST_MAX_CONCURRENCY=6
ALTENAR_PREMATCH_SCHEDULER_BURST_MAX_EVENTS_PER_TICK=14
ALTENAR_PREMATCH_SCHEDULER_BURST_WINDOW_MINUTES=120
ALTENAR_PREMATCH_SCHEDULER_BURST_STALE_THRESHOLD_MS=360000
ALTENAR_PREMATCH_SCHEDULER_BURST_MIN_LINKED_STALE=8
ALTENAR_PREMATCH_SCHEDULER_CAPACITY_LOG_INTERVAL_MS=60000

# Kelly / Bankroll Base
KELLY_BASE_MODE=NAV
KELLY_FRACTION_PREMATCH_VALUE=0.22
KELLY_FRACTION_LIVE_VALUE=0.10
KELLY_FRACTION_LIVE_SNIPE=0.08
KELLY_FRACTION_MANUAL=0.10
KELLY_FRACTION_DEFAULT=0.10

# Live tuning (desbloqueo de oportunidades en días de feed ruidoso)
LIVE_VALUE_MIN_EV=0.02
LIVE_VALUE_MIN_DISPLAY_STAKE=0.10
LIVE_VALUE_NON_1X2_STAKE_FACTOR=1
LIVE_SNIPE_REQUIRE_PINNACLE_LIVE=false
LIVE_VALUE_REQUIRE_SCORE_SYNC=false
LIVE_VALUE_SCORE_SYNC_MAX_GOAL_DIFF=1
LIVE_VALUE_ENABLE_STABILITY_FILTER=true
LIVE_VALUE_STABILITY_MIN_HITS=1
LIVE_VALUE_STABILITY_MIN_AGE_MS=1500
LIVE_GLOBAL_STABILITY_ENABLED=true
LIVE_GLOBAL_STABILITY_MIN_HITS=1

# Auto-placement SOLO para LIVE_SNIPE / LA_VOLTEADA
# Perfil por defecto del ejemplo: auto-colocacion REAL habilitada.
# Cambio rapido de perfil:
# SIMULADO:
#   BOOKY_REAL_PLACEMENT_ENABLED=false
#   AUTO_SNIPE_ENABLED=true
#   AUTO_SNIPE_DRY_RUN=false
#   AUTO_SNIPE_REQUIRE_REAL_PLACEMENT_ENABLED=false
# Proveedor de colocacion para auto-placement: booky | pinnacle
# Puede cambiarse en caliente via API:
#   GET  /api/opportunities/live/placement-provider
#   POST /api/opportunities/live/placement-provider {"provider":"pinnacle"}
# Si no se define, usa booky por defecto.
# AUTO_PLACEMENT_PROVIDER=booky
# REAL:
#   BOOKY_REAL_PLACEMENT_ENABLED=true
#   AUTO_SNIPE_ENABLED=true
#   AUTO_SNIPE_DRY_RUN=false
#   AUTO_SNIPE_REQUIRE_REAL_PLACEMENT_ENABLED=true
AUTO_SNIPE_ENABLED=true
AUTO_SNIPE_DRY_RUN=false
AUTO_SNIPE_MIN_EV_PERCENT=2
AUTO_SNIPE_MIN_STAKE_SOL=1
AUTO_SNIPE_MAX_BETS_PER_HOUR=3
AUTO_SNIPE_COOLDOWN_PER_PICK_MS=180000
AUTO_SNIPE_REENTRY_MIN_ODD_IMPROVEMENT_PCT=8
AUTO_SNIPE_REENTRY_MIN_ODD_POINTS=0.30
AUTO_SNIPE_MAX_ENTRIES_PER_PICK=2
AUTO_SNIPE_REQUIRE_REAL_PLACEMENT_ENABLED=true

# Recalculo prematch en caliente al presionar/confirmar apostar
PREMATCH_REFRESH_RECALCULATE_PINNACLE=true
PREMATCH_PINNACLE_CACHE_TTL_MS=15000

# Diagnosticos de arbitraje (persistencia + inventario periodico)
# Guarda snapshots de rechazo/generacion para auditoria y estadisticas.
ARBITRAGE_DIAG_MAX_HISTORY=5000
ARBITRAGE_DIAG_SUMMARY_WINDOW_MINUTES=180
ARBITRAGE_DIAGNOSTICS_INVENTORY_ENABLED=true
ARBITRAGE_DIAGNOSTICS_INVENTORY_INTERVAL_MS=60000
# Evita arbitrajes con cuotas Altenar desactualizadas (ms). Default backend: 900000 (15 min).
ARBITRAGE_ALTENAR_MAX_ODD_AGE_MS=900000

# Ventana híbrida Prematch (deslizante + precarga)
# Ejemplo: ahora+6h (primaria) + ahora+6h adicionales (precarga) con overlap de 30m
PREMATCH_WINDOW_PRIMARY_HOURS=3
PREMATCH_WINDOW_PREFETCH_HOURS=3
PREMATCH_WINDOW_OVERLAP_MINUTES=30

# Control granular de workers (útil en sábados de alta carga)
# Master switch (si está en true, apaga todos):
# DISABLE_BACKGROUND_WORKERS=true

# Switches finos (default = false cuando no existen):
# DISABLE_LIVE_SCANNER=false
# DISABLE_PREMATCH_SCHEDULER=false
# DISABLE_PINNACLE_INGEST_CRON=false
# DISABLE_PINNACLE_PREMATCH_WS=false
DISABLE_MONITOR_DASHBOARD=false

# Retención de cache de eventos (minutos) para evitar saturar db.json
# DB_UPCOMING_RETENTION_MINUTES=180
# DB_ALTENAR_RETENTION_MINUTES=180
